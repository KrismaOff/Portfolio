}\cell\pard\intbl\itap1{\fs50\b \uc0\u1041 \uc0\u1086 \uc0\u1095 \uc0\u1080 \uc0\u1085  \uc0\u1050 \uc0\u1080 \uc0\u1088 \uc0\u1080 \uc0\u1083 \uc0\u1083  \uc0\u1040 \uc0\u1088 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1086 \uc0\u1074 \uc0\u1080 \uc0\u1095 }\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1052 \uc0\u1091 \uc0\u1078 \uc0\u1095 \uc0\u1080 \uc0\u1085 \uc0\u1072 , 18\uc0\u160 \uc0\u1083 \uc0\u1077 \uc0\u1090 , \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1080 \uc0\u1083 \uc0\u1089 \uc0\u1103  11 \uc0\u1072 \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1083 \uc0\u1103  2003}\par\pard\intbl\sl260{\fs18 \par +7\uc0\u160 (925)\uc0\u160 4304444 {\cf1\emdash  \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1087 \uc0\u1086 \uc0\u1095 \uc0\u1080 \uc0\u1090 \uc0\u1072 \uc0\u1077 \uc0\u1084 \uc0\u1099 \uc0\u1081  \uc0\u1089 \uc0\u1087 \uc0\u1086 \uc0\u1089 \uc0\u1086 \uc0\u1073  \uc0\u1089 \uc0\u1074 \uc0\u1103 \uc0\u1079 \uc0\u1080 }\par {{\field{\*\fldinst HYPERLINK "mailto:kirillb2003@bk.ru"}{\fldrslt\ul kirillb2003@bk.ru}}}}\par\pard\intbl\sl260{\fs18 \par \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1078 \uc0\u1080 \uc0\u1074 \uc0\u1072 \uc0\u1077 \uc0\u1090 : \uc0\u1052 \uc0\u1086 \uc0\u1089 \uc0\u1082 \uc0\u1074 \uc0\u1072 , \uc0\u1084 . \uc0\u1063 \uc0\u1077 \uc0\u1088 \uc0\u1090 \uc0\u1072 \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1089 \uc0\u1082 \uc0\u1072 \uc0\u1103 \par \uc0\u1043 \uc0\u1088 \uc0\u1072 \uc0\u1078 \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1086 : \uc0\u1056 \uc0\u1086 \uc0\u1089 \uc0\u1089 \uc0\u1080 \uc0\u1103 , \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1100  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1077 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1085 \uc0\u1072  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1091 : \uc0\u1056 \uc0\u1086 \uc0\u1089 \uc0\u1089 \uc0\u1080 \uc0\u1103 \par \uc0\u1053 \uc0\u1077  \uc0\u1075 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1082  \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1077 \uc0\u1079 \uc0\u1076 \uc0\u1091 , \uc0\u1085 \uc0\u1077  \uc0\u1075 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1082  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1072 \uc0\u1084 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1046 \uc0\u1077 \uc0\u1083 \uc0\u1072 \uc0\u1077 \uc0\u1084 \uc0\u1072 \uc0\u1103  \uc0\u1076 \uc0\u1086 \uc0\u1083 \uc0\u1078 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100  \uc0\u1080  \uc0\u1079 \uc0\u1072 \uc0\u1088 \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1090 \uc0\u1072 }\cell\row\trowd\cellx6861\clvertalc\cellx9638\pard\intbl\itap1\sa100\sl280{\fs24\b Frontend-\uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1095 \uc0\u1080 \uc0\u1082 }\pard\intbl\itap1\sl260{\fs18 \par{\uc0\u1048 \uc0\u1085 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1086 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1080 , \uc0\u1080 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1085 \uc0\u1077 \uc0\u1090 , \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1082 \uc0\u1086 \uc0\u1084 }\par\li300{\uc0\u8226  \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1084 \uc0\u1084 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 , \uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072 \par\uc0\u8226  Web \uc0\u1080 \uc0\u1085 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1088 \par\uc0\u8226  Web \uc0\u1084 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1088 }\par\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1047 \uc0\u1072 \uc0\u1085 \uc0\u1103 \uc0\u1090 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100 : \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 , \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1078 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1072 , \uc0\u1095 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1095 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1103 \uc0\u1090 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100 , \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1103 \uc0\u1090 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100 \par \uc0\u1043 \uc0\u1088 \uc0\u1072 \uc0\u1092 \uc0\u1080 \uc0\u1082  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099 : \uc0\u1074 \uc0\u1072 \uc0\u1093 \uc0\u1090 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1081  \uc0\u1084 \uc0\u1077 \uc0\u1090 \uc0\u1086 \uc0\u1076 , \uc0\u1091 \uc0\u1076 \uc0\u1072 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 , \uc0\u1075 \uc0\u1080 \uc0\u1073 \uc0\u1082 \uc0\u1080 \uc0\u1081  \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1092 \uc0\u1080 \uc0\u1082 , \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1076 \uc0\u1077 \uc0\u1085 \uc0\u1100 , \uc0\u1089 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1092 \uc0\u1080 \uc0\u1082 \par \line\uc0\u1046 \uc0\u1077 \uc0\u1083 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1077  \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1084 \uc0\u1103  \uc0\u1074  \uc0\u1087 \uc0\u1091 \uc0\u1090 \uc0\u1080  \uc0\u1076 \uc0\u1086  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099 : \uc0\u1085 \uc0\u1077  \uc0\u1080 \uc0\u1084 \uc0\u1077 \uc0\u1077 \uc0\u1090  \uc0\u1079 \uc0\u1085 \uc0\u1072 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 }}\cell \pard\intbl\itap1\qr{\fs32\qc\b 30\uc0\u160 000}\line{\fs18\sl260 \uc0\u1088 \uc0\u1091 \uc0\u1073 .}\par\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1054 \uc0\u1087 \uc0\u1099 \uc0\u1090  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099  \emdash 1 \uc0\u1075 \uc0\u1086 \uc0\u1076  7 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 \uc0\u1077 \uc0\u1074 }\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 \uc0\u1040 \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1083 \uc0\u1100  2020 \emdash  \uc0\u1085 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1086 \uc0\u1103 \uc0\u1097 \uc0\u1077 \uc0\u1077  \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1084 \uc0\u1103 \line 1 \uc0\u1075 \uc0\u1086 \uc0\u1076  7 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 \uc0\u1077 \uc0\u1074 }\cell\pard\intbl\itap1\par\cell\pard\intbl\itap1\sl280{\fs24\b ItHUB}\par\pard\intbl\itap1\sl260{\fs18\cf1 }\par\pard\intbl\itap1\sl280\sb60\sa60{\fs24 Frontend-\uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1095 \uc0\u1080 \uc0\u1082 , project-manager  \par}\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u1054 \uc0\u1090 \uc0\u1074 \uc0\u1077 \uc0\u1095 \uc0\u1072 \uc0\u1083  \uc0\u1079 \uc0\u1072  front \uc0\u1095 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1100 , \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1084 \uc0\u1072 \uc0\u1083 \uc0\u1089 \uc0\u1103  \uc0\u1074 \uc0\u1077 \uc0\u1088 \uc0\u1089 \uc0\u1090 \uc0\u1082 \uc0\u1086 \uc0\u1081  \uc0\u1085 \uc0\u1072  React, \uc0\u1091 \uc0\u1095 \uc0\u1091 \uc0\u1074 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1074  "\uc0\u1085 \uc0\u1072 \uc0\u1087 \uc0\u1080 \uc0\u1089 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1080 " \uc0\u1076 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1081 \uc0\u1085 \uc0\u1072 , \uc0\u1088 \uc0\u1091 \uc0\u1082 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1080 \uc0\u1083  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1094 \uc0\u1077 \uc0\u1089 \uc0\u1089 \uc0\u1086 \uc0\u1084  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1080 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1054 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sl220{\fs22\uc0\u1057 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1085 \uc0\u1077 \uc0\u1077  \uc0\u1089 \uc0\u1087 \uc0\u1077 \uc0\u1094 \uc0\u1080 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1077 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 2023}\cell\pard\intbl\itap1\sl280{\fs24\b ItHUB}\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1084 \uc0\u1084 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  , Web \uc0\u1080  \uc0\u1084 \uc0\u1091 \uc0\u1083 \uc0\u1100 \uc0\u1090 \uc0\u1080 \uc0\u1084 \uc0\u1077 \uc0\u1076 \uc0\u1080 \uc0\u1081 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1055 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1082 \uc0\u1074 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1092 \uc0\u1080 \uc0\u1082 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 , \uc0\u1082 \uc0\u1091 \uc0\u1088 \uc0\u1089 \uc0\u1099 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 2021}\cell\pard\intbl\itap1\sl280{\fs24\b "\uc0\u1064 \uc0\u1082 \uc0\u1086 \uc0\u1083 \uc0\u1072  \uc0\u1040 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1074 \uc0\u1072 " - \uc0\u1086 \uc0\u1088 \uc0\u1075 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103  \uc0\u1084 \uc0\u1077 \uc0\u1088 \uc0\u1086 \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1103 \uc0\u1090 \uc0\u1080 \uc0\u1081  }\par\pard\intbl\itap1\sl260{\fs18 Ithub }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 2020}\cell\pard\intbl\itap1\sb250\sl280{\fs24\b Intel AI for youth }\par\pard\intbl\itap1\sl260{\fs18 Intel}\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 2020}\cell\pard\intbl\itap1\sb250\sl280{\fs24\b \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1092 \uc0\u1077 \uc0\u1089 \uc0\u1089 \uc0\u1080 \uc0\u1103  Front-end \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1095 \uc0\u1080 \uc0\u1082  }\par\pard\intbl\itap1\sl260{\fs18 ItProger}\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1050 \uc0\u1083 \uc0\u1102 \uc0\u1095 \uc0\u1077 \uc0\u1074 \uc0\u1099 \uc0\u1077  \uc0\u1085 \uc0\u1072 \uc0\u1074 \uc0\u1099 \uc0\u1082 \uc0\u1080 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 \uc0\u1047 \uc0\u1085 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1103 \uc0\u1079 \uc0\u1099 \uc0\u1082 \uc0\u1086 \uc0\u1074 }\cell\pard\intbl\itap1\sl260{\fs18 \uc0\u1056 \uc0\u1091 \uc0\u1089 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  {\cf1\emdash  \uc0\u1056 \uc0\u1086 \uc0\u1076 \uc0\u1085 \uc0\u1086 \uc0\u1081 }\par \uc0\u1040 \uc0\u1085 \uc0\u1075 \uc0\u1083 \uc0\u1080 \uc0\u1081 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  {\cf1\emdash  B2 \uc0\u8212  \uc0\u1057 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1085 \uc0\u1077 -\uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1074 \uc0\u1080 \uc0\u1085 \uc0\u1091 \uc0\u1090 \uc0\u1099 \uc0\u1081 }}\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 \uc0\u1053 \uc0\u1072 \uc0\u1074 \uc0\u1099 \uc0\u1082 \uc0\u1080 }\cell\pard\intbl\itap1\sb250\sl260{\fs18 {\cb5\chcfpat5\chcbpat5 \uc0\u1054 \uc0\u1088 \uc0\u1075 \uc0\u1072 \uc0\u1085 