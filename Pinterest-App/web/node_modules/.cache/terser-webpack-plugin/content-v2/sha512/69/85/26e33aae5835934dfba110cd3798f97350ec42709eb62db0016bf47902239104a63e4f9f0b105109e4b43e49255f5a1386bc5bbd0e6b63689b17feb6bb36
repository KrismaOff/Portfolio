"20\" height=\"20\" fill=\"black\" className=\"bi bi-box-arrow-up-right\" viewBox=\"0 0 16 16\">\r\n                                    <path fillRule=\"evenodd\" d=\"M8.636 3.5a.5.5 0 0 0-.5-.5H1.5A1.5 1.5 0 0 0 0 4.5v10A1.5 1.5 0 0 0 1.5 16h10a1.5 1.5 0 0 0 1.5-1.5V7.864a.5.5 0 0 0-1 0V14.5a.5.5 0 0 1-.5.5h-10a.5.5 0 0 1-.5-.5v-10a.5.5 0 0 1 .5-.5h6.636a.5.5 0 0 0 .5-.5z\" />\r\n                                    <path fillRule=\"evenodd\" d=\"M16 .5a.5.5 0 0 0-.5-.5h-5a.5.5 0 0 0 0 1h3.793L6.146 9.146a.5.5 0 1 0 .708.708L15 1.707V5.5a.5.5 0 0 0 1 0v-5z\" />\r\n                                </svg>\r\n                            </a>\r\n                        </div>\r\n\r\n                        <div className=\"title-ex-post\">{title}</div>\r\n                        <div className=\"hr-ex-post\"></div>\r\n                        <div className=\"text-ex-post\">{text}</div>\r\n\r\n                        <div className=\"comment-save-block-post\">\r\n                            <div className=\"tags-ex-post\">{tags}</div>\r\n                            <div className=\"btn-group btn-group-ex-post\">\r\n                                <button className={btnCol ? \"btn btn-ex-post btn-secondary btn-red\" : \"btn btn-ex-post btn-secondary\"} onClick={() => {\r\n                                    const arr = {\r\n                                        tags: tags,\r\n                                        title: title,\r\n                                        author: author,\r\n                                        text: text,\r\n                                        img: img,\r\n                                        link: link,\r\n                                        id: id\r\n                                    }\r\n                                    \r\n                                    if (btnCol) {\r\n                                        setBtnCol(false)\r\n                                    } else {\r\n                                   